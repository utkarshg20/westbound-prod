{
  "name": "supervisor-outreach",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 9 1 * *" }] }
      },
      "name": "Monthly 1st 9am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.WORKER_API_URL}}/api/jobs/enqueue",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "x-n8n-secret", "value": "={{$env.N8N_WEBHOOK_SECRET}}" }]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "type", "value": "sync.supervisor_outreach" },
            { "name": "payload", "value": "{}" }
          ]
        }
      },
      "name": "Enqueue outreach drafts",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    }
  ],
  "connections": {
    "Monthly 1st 9am": {
      "main": [[{ "node": "Enqueue outreach drafts", "type": "main", "index": 0 }]]
    }
  }
}

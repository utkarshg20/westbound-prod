# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=westbound-assets
R2_PUBLIC_URL=

# Redis / Upstash (job queue)
REDIS_URL=redis://localhost:6379

# LLM
ANTHROPIC_API_KEY=

# Adapters: set USE_STUB_ADAPTERS=false when API keys are filled
USE_STUB_ADAPTERS=true

# Music / video APIs (configure as you onboard)
SUNO_API_KEY=
SUNO_API_BASE=https://api.suno.ai
KLING_API_KEY=
KLING_API_BASE=https://api.klingai.com
HEDRA_API_KEY=
HEDRA_API_BASE=https://api.hedra.com
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
CREATOMATE_API_KEY=
CREATOMATE_TEMPLATE_FACELESS=
CREATOMATE_TEMPLATE_SHORTS=
REPLICATE_API_TOKEN=
REPLICATE_FACE_MODEL_VERSION=
SEEDANCE_API_KEY=
SEEDANCE_API_BASE=
UDIO_API_KEY=
UDIO_API_BASE=
MUSIC_PROVIDER=suno
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
DISTROKID_API_KEY=
IDENTIFYY_API_KEY=
SONGTRADR_API_KEY=

# Sync signal sources
SIGNAL_CSV_PATH=infra/supabase/sample-signals.csv
SONGTRADR_BRIEFS_CSV=
SYNC_BATCH_LIMIT=13

# Observability
SENTRY_DSN=
GIT_SHA=
LOG_LEVEL=info

# n8n webhook (worker callbacks)
N8N_WEBHOOK_SECRET=
N8N_ENCRYPTION_KEY=
WORKER_API_URL=http://localhost:3001
WORKER_PORT=3001

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
REQUIRE_DAN_AUTH=false
YT_ROTATE_VIDEO_ID=

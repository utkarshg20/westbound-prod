{
  "name": "westbound",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck",
    "db:gen-types": "echo 'Run: supabase gen types typescript --workdir infra/supabase > packages/platform/src/database.types.ts'",
    "db:migrate": "supabase db push --workdir infra/supabase",
    "worker": "pnpm --filter @westbound/worker dev",
    "dashboard": "pnpm --filter @westbound/dashboard dev",
    "health": "tsx scripts/check-health.ts",
    "setup:week0": "bash scripts/setup-week0.sh",
    "sync:mvp": "tsx scripts/run-sync-mvp.ts",
    "youtube:proof": "tsx scripts/run-youtube-proof.ts",
    "youtube:loops": "tsx scripts/generate-visual-loops.ts",
    "ingest:refs": "bash scripts/ingest-dan-refs.sh",
    "trend:scrape": "tsx scripts/trend-scraper.ts",
    "sammy:dry-runs": "tsx scripts/run-sammy-dry-runs.ts",
    "vendor:flux": "tsx scripts/vendor-test-flux.ts",
    "vendor:suno": "tsx scripts/vendor-test-suno.ts",
    "vendor:video": "tsx scripts/vendor-test-video.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^9.28.0",
    "tsx": "^4.19.4",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
